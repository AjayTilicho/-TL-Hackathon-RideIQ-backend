PORT=5001
MONGODB_URI=mongodb://127.0.0.1:27017/rideiq

# Auth — set JWT_SECRET in production (min 32 random bytes recommended)
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d
AUTH_COOKIE_NAME=rideiq_token

# CORS: the API reflects any browser Origin and sends credentials (cookies). Lock down at your reverse proxy in production if needed.

# Google AI — document extraction + personalized dashboard tips (Gemini; requires key).
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Local Ollama — bike photo scan only (OLLAMA_VISION_MODEL). /api/ai/models lists these tags.
OLLAMA_URL=http://127.0.0.1:11434
OLLAMA_VISION_MODEL=llava
OLLAMA_NUM_PREDICT=900

# If bike scan fails with Ollama 500: use a smaller vision model or lower OLLAMA_NUM_PREDICT; check Ollama logs.

# Community bunks: MongoDB collections petrolbunks, bunkratings, bunkcomments (seeded on first request).
